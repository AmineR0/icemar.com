    { "source": "/about", "destination": "/server.js" },
    { "source": "/faq", "destination": "/server.js" },
    { "source": "/contact", "destination": "/server.js" },
    { "source": "/privacy", "destination": "/server.js" },
    { "source": "/terms", "destination": "/server.js" },
    { "source": "/verificateur-ice", "destination": "/server.js" },
    { "source": "/cachet-entreprise", "destination": "/server.js" },
    { "source": "/simulation-salaire", "destination": "/server.js" },
    { "source": "/generateur-facture", "destination": "/server.js" },
    { "source": "/chiffres-en-lettres", "destination": "/server.js" },
    { "source": "/outils-societe", "destination": "/server.js" },
    { "source": "/recherche-ice-maroc", "destination": "/server.js" },
    { "source": "/annuaire-entreprises-marocaines", "destination": "/server.js" },
    { "source": "/top-recherches-ice", "destination": "/server.js" },
    { "source": "/entreprise/(.*)", "destination": "/server.js" },
    { "source": "/ice/(.*)", "destination": "/server.js" },
    { "source": "/ville/(.*)", "destination": "/server.js" },
    { "source": "/categorie/(.*)", "destination": "/server.js" }
  ]
