{
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server.js" },
    { "source": "/robots.txt", "destination": "/server.js" },
    { "source": "/sitemap.xml", "destination": "/server.js" },
    { "source": "/recherche-ice-maroc", "destination": "/server.js" },
    { "source": "/annuaire-entreprises-marocaines", "destination": "/server.js" },
    { "source": "/top-recherches-ice", "destination": "/server.js" },
    { "source": "/entreprise/(.*)", "destination": "/server.js" },
    { "source": "/ice/(.*)", "destination": "/server.js" },
    { "source": "/ville/(.*)", "destination": "/server.js" },
    { "source": "/categorie/(.*)", "destination": "/server.js" }
  ]
}
